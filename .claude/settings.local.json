      "Bash(chromedriver --version)",
      "Read(//usr/local/bin/**)",
      "Bash(brew list:*)",
      "Bash(gem list:*)",
      "Bash(find /opt/scripts -name \"dynamic_env*\" -o -name \"*.sh\" 2>/dev/null | head -20)",
      "Read(//opt/**)"
    ]
  }
